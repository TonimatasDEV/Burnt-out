CREATE TABLE OrganizacionEntity (
    ID_Org INTEGER NOT NULL PRIMARY KEY,
    Org_Name TEXT NOT NULL
);

CREATE TABLE UsuarioEntity (
    ID_Usuario INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    Username TEXT NOT NULL UNIQUE,
    Contrasena TEXT NOT NULL,
    Nombre TEXT NOT NULL,
    Riesgo_Burnout REAL,
    Descripcion TEXT,
    FK_ID_Organizacion INTEGER NOT NULL,
    FOREIGN KEY(FK_ID_Organizacion) REFERENCES OrganizacionEntity(ID_Org)
);

CREATE TABLE AjusteEntity (
    ID_Ajuste INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    Nombre_Ajuste TEXT NOT NULL
);

CREATE TABLE TableroEntity (
    ID_Tabl INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    Titulo TEXT NOT NULL,
    FK_ID_Org INTEGER NOT NULL,
    FK_ID_Equipo INTEGER,
    FOREIGN KEY(FK_ID_Org) REFERENCES OrganizacionEntity(ID_Org)
);

CREATE TABLE EquipoEntity (
    ID_Equipo INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    Titulo TEXT NOT NULL,
    Puntuacion INTEGER DEFAULT 0,
    FK_ID_Org INTEGER NOT NULL,
    FOREIGN KEY(FK_ID_Org) REFERENCES OrganizacionEntity(ID_Org)
);

CREATE TABLE PreguntaEntity (
    ID_Pregunta INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    Pregunta TEXT NOT NULL,
    FK_ID_Org INTEGER NOT NULL,
    FOREIGN KEY(FK_ID_Org) REFERENCES OrganizacionEntity(ID_Org)
);

CREATE TABLE TareaEntity (
    ID_Tarea INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    Titulo TEXT NOT NULL,
    Descripcion TEXT,
    Estado TEXT NOT NULL,
    FK_ID_Tabl INTEGER NOT NULL,
    FK_ID_Usuario INTEGER NOT NULL,
    FOREIGN KEY(FK_ID_Tabl) REFERENCES TableroEntity(ID_Tabl),
    FOREIGN KEY(FK_ID_Usuario) REFERENCES UsuarioEntity(ID_Usuario)
);

CREATE TABLE SubtareaEntity (
    ID_Subtarea INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    Titulo TEXT NOT NULL,
    Completado INTEGER NOT NULL,
    FK_ID_Tarea INTEGER NOT NULL,
    FOREIGN KEY(FK_ID_Tarea) REFERENCES TareaEntity(ID_Tarea)
);

CREATE TABLE User_TeamEntity (
    ID_Usuario INTEGER NOT NULL,
    ID_Equipo INTEGER NOT NULL,
    PRIMARY KEY (ID_Usuario, ID_Equipo),
    FOREIGN KEY(ID_Usuario) REFERENCES UsuarioEntity(ID_Usuario),
    FOREIGN KEY(ID_Equipo) REFERENCES EquipoEntity(ID_Equipo)
);

CREATE TABLE Ajuste_UserEntity (
    ID_Usuario INTEGER NOT NULL,
    ID_Ajuste INTEGER NOT NULL,
    Valor_Ajuste TEXT,
    PRIMARY KEY (ID_Usuario, ID_Ajuste),
    FOREIGN KEY(ID_Usuario) REFERENCES UsuarioEntity(ID_Usuario),
    FOREIGN KEY(ID_Ajuste) REFERENCES AjusteEntity(ID_Ajuste)
);

CREATE TABLE ResponderEntity (
    ID_Usuario INTEGER NOT NULL,
    ID_Pregunta INTEGER NOT NULL,
    Anonimo INTEGER NOT NULL,
    Respuesta TEXT NOT NULL,
    PRIMARY KEY (ID_Usuario, ID_Pregunta),
    FOREIGN KEY(ID_Usuario) REFERENCES UsuarioEntity(ID_Usuario),
    FOREIGN KEY(ID_Pregunta) REFERENCES PreguntaEntity(ID_Pregunta)
);

CREATE TABLE OperacionPendienteEntity (
    ID_Operacion INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    tipo_accion TEXT NOT NULL,
    tabla_afectada TEXT NOT NULL,
    id_afectado INTEGER NOT NULL,
    datos_json TEXT NOT NULL,
    timestamp_creacion INTEGER NOT NULL,
    sincronizado INTEGER DEFAULT 0
);

CREATE INDEX idx_sync_log_sincronizado ON OperacionPendienteEntity(sincronizado);
CREATE INDEX idx_sync_log_tabla ON OperacionPendienteEntity(tabla_afectada);
CREATE INDEX idx_sync_log_timestamp ON OperacionPendienteEntity(timestamp_creacion);

-- ======= QUERIES =======

insertOrgbase:
INSERT OR IGNORE INTO OrganizacionEntity(Org_Name) VALUES('Organizacion Predeterminada');

insertEquipoBase:
INSERT OR IGNORE INTO EquipoEntity(Titulo, FK_ID_Org) VALUES('Equipo Predeterminado', 1);

insertAjustes:
INSERT OR IGNORE INTO AjusteEntity(Nombre_Ajuste) VALUES('Notificaciones');
INSERT OR IGNORE INTO AjusteEntity(Nombre_Ajuste) VALUES('Tema Oscuro');

insertUsuarioBase:
INSERT OR IGNORE INTO UsuarioEntity(Username, Contrasena, Nombre, FK_ID_Organizacion) VALUES('User', '********', 'Usuario Base', 1);
INSERT OR IGNORE INTO User_TeamEntity(ID_Usuario, ID_Equipo) VALUES(1, 1);

-- ====== TAREAS ======

insertTarea:
INSERT INTO TareaEntity(Titulo, Descripcion, Estado, FK_ID_Tabl, FK_ID_Usuario)
VALUES(?, ?, ?, ?, ?);

insertOrUpdateTarea:
INSERT OR REPLACE INTO TareaEntity(ID_Tarea, Titulo, Descripcion, Estado, FK_ID_Tabl, FK_ID_Usuario)
VALUES(?, ?, ?, ?, ?, ?);

getTareaById:
SELECT * FROM TareaEntity WHERE ID_Tarea = ?;

updateTareaById:
UPDATE TareaEntity SET Titulo = ?, Descripcion = ?, Estado = ? WHERE ID_Tarea = ?;

deleteTareaById:
DELETE FROM TareaEntity WHERE ID_Tarea = ?;

deleteTareasByTablero:
DELETE FROM TareaEntity WHERE FK_ID_Tabl = ?;

-- ===== Operaciones Pendientes =====
insertOperacionPendiente:
INSERT INTO OperacionPendienteEntity(tipo_accion, tabla_afectada, id_afectado, datos_json, timestamp_creacion, sincronizado)
VALUES(?, ?, ?, ?, ?, ?);

getOperacionesPendientes:
SELECT * FROM OperacionPendienteEntity WHERE sincronizado = 0 ORDER BY timestamp_creacion
LIMIT ?;

deleteOperacionesPendientesById:
DELETE FROM OperacionPendienteEntity WHERE ID_Operacion = ?;

cambiarEstadoOperacionPendiente:
UPDATE OperacionPendienteEntity SET sincronizado = ? WHERE ID_Operacion = ?;

deleteOperacionesPorEstado:
DELETE FROM OperacionPendienteEntity WHERE sincronizado = ?;


-- ===== OTROS =====

insertTablero:
INSERT INTO TableroEntity(Titulo, FK_ID_Equipo, FK_ID_Org)
VALUES(?, ?, ?);

insertEquipo:
INSERT INTO EquipoEntity(Titulo, FK_ID_Org)
VALUES(?, ?);

getTareasByTablero:
SELECT * FROM TareaEntity WHERE FK_ID_Tabl = ?;

getTablerosByOrg:
SELECT * FROM TableroEntity WHERE FK_ID_Org = ?;

getUserById:
SELECT * FROM UsuarioEntity WHERE ID_Usuario = ?;

getEquipoById:
SELECT * FROM EquipoEntity WHERE ID_Equipo = ?;

getEquiposByOrg:
SELECT * FROM EquipoEntity WHERE FK_ID_Org = ?;

getUsuariosByEquipo:
SELECT u.*
FROM UsuarioEntity u JOIN User_TeamEntity ut ON u.ID_Usuario = ut.ID_Usuario
WHERE ut.ID_Equipo = ?;

getAjustesByUser:
SELECT a.Nombre_Ajuste, au.Valor_Ajuste
FROM AjusteEntity a JOIN Ajuste_UserEntity au ON a.ID_Ajuste = au.ID_Ajuste
WHERE au.ID_Usuario = ?;

getOrganizacionById:
SELECT * FROM OrganizacionEntity WHERE ID_Org = ?;

getPreguntasByOrg:
SELECT * FROM PreguntaEntity WHERE FK_ID_Org = ?;

getRespuestasByPregunta:
SELECT r.Respuesta, r.Anonimo, u.Nombre
FROM ResponderEntity r JOIN UsuarioEntity u ON r.ID_Usuario = u.ID_Usuario
WHERE r.ID_Pregunta = ?;
